<Window x:Class="WPF.RaporWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📊 Detaylı Sistem ve Arıza Raporları" Height="650" Width="1050"
        Background="#181B21" WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ÜST PANEL: FİLTRELER VE BUTONLAR -->
        <Border Grid.Row="0" Background="#21252D" CornerRadius="6" Padding="15" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Color="#000000" Opacity="0.4"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Zaman Aralığı:" Foreground="#ABB2BF" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>

                <ComboBox x:Name="cmbZamanFiltresi" Grid.Column="1" Width="140" Height="30" Margin="0,0,25,0" VerticalContentAlignment="Center" SelectionChanged="cmbZamanFiltresi_SelectionChanged">
                    <ComboBoxItem Content="Tüm Zamanlar" IsSelected="True"/>
                    <ComboBoxItem Content="Bu Oturum"/>
                    <ComboBoxItem Content="Son 24 Saat"/>
                    <ComboBoxItem Content="Son 3 Gün"/>
                    <ComboBoxItem Content="Son 1 Hafta"/>
                    <ComboBoxItem Content="Son 1 Ay"/>
                </ComboBox>

                <TextBlock Grid.Column="2" Text="Loglarda Ara:" Foreground="#ABB2BF" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                <TextBox x:Name="txtArama" Grid.Column="3" Height="30" Padding="5" Background="#181B21" Foreground="White" BorderBrush="#313743" BorderThickness="1" TextChanged="txtArama_TextChanged"/>

                <Button x:Name="btnYenile" Grid.Column="4" Content="🔄 Yenile" Width="100" Height="32" Margin="15,0,10,0" Background="#61AFEF" Foreground="#181B21" FontWeight="Bold" Cursor="Hand" Click="btnYenile_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="btnExcel" Grid.Column="5" Content="📗 Excel'e Aktar" Width="130" Height="32" Background="#98C379" Foreground="#181B21" FontWeight="Bold" Cursor="Hand" Click="btnExcel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <!-- ORTA PANEL: DATAGRID (TABLO) -->
        <Border Grid.Row="1" Background="#21252D" CornerRadius="6" Padding="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Color="#000000" Opacity="0.4"/>
            </Border.Effect>

            <!-- SelectionMode ve SelectionUnit hataları düzeltildi, LoadingRow eventi eklendi -->
            <DataGrid x:Name="dgvAlarmlar" AutoGenerateColumns="False" IsReadOnly="True" 
                      Background="Transparent" BorderThickness="0" RowHeaderWidth="0" 
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#313743" 
                      HeadersVisibility="Column" SelectionMode="Extended" SelectionUnit="FullRow"
                      LoadingRow="dgvAlarmlar_LoadingRow">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#181B21"/>
                        <Setter Property="Foreground" Value="#E5C07B"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="BorderThickness" Value="0,0,0,2"/>
                        <Setter Property="BorderBrush" Value="#313743"/>
                    </Style>

                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Margin" Value="0,2"/>
                    </Style>

                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Oluşma Zamanı" Binding="{Binding Tarih, StringFormat='dd.MM.yyyy HH:mm:ss'}" Width="150"/>
                    <DataGridTextColumn Header="Olay Açıklaması" Binding="{Binding Mesaj}" Width="*"/>
                    <DataGridTextColumn Header="Kategori" Binding="{Binding Tip}" Width="120"/>
                    <DataGridTextColumn Header="Oturum ID" Binding="{Binding CalismaOturumu}" Width="180"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ALT PANEL: DURUM ÇUBUĞU -->
        <TextBlock x:Name="lblDurum" Grid.Row="2" Text="Veriler yükleniyor..." Foreground="#ABB2BF" FontWeight="Bold" Margin="0,10,0,0" HorizontalAlignment="Right"/>
    </Grid>
</Window>